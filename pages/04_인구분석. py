import streamlit as st
import pandas as pd
import matplotlib.pyplot as plt

# 한글 깨짐 방지
plt.rcParams['font.family'] = 'Malgun Gothic'
plt.rcParams['axes.unicode_minus'] = False

# 데이터 불러오기
df = pd.read_csv("population (2).csv")

# 컬럼 자동 찾기
region_col = None
age_col = None
population_col = None

for col in df.columns:
    c = str(col)

    if ('구' in c or '행정' in c or '지역' in c) and region_col is None:
        region_col = col

    if ('나이' in c or '연령' in c) and age_col is None:
        age_col = col

    if ('인구' in c) and population_col is None:
        population_col = col

# 숫자 변환
df[population_col] = (
    df[population_col]
    .astype(str)
    .str.replace(',', '')
)

df[population_col] = pd.to_numeric(df[population_col])

# 제목
st.title("서울시 행정구별 인구수")

# 행정구 선택
districts = sorted(df[region_col].dropna().unique())

selected = st.selectbox(
    "행정구 선택",
    districts
)

# 필터링
filtered_df = df[df[region_col] == selected]

# 나이순 정렬
filtered_df = filtered_df.sort_values(age_col)

# 그래프
fig, ax = plt.subplots(figsize=(12, 6))

# 회색 배경
fig.patch.set_facecolor("lightgray")
ax.set_facecolor("lightgray")

# 빨간색 꺾은선
ax.plot(
    filtered_df[age_col],
    filtered_df[population_col],
    color="red",
    linewidth=3,
    marker="o"
)

# 제목
ax.set_title("서울시 행정구별 인구수", fontsize=20)

# 축 이름
ax.set_xlabel("나이")
ax.set_ylabel("인구수")

# 격자
ax.grid(True, linestyle="--", alpha=0.5)

# 출력
st.pyplot(fig)
